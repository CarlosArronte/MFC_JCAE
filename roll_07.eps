  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 375
  /ImageMatrix [175 0 0 375 0 0]
  /Width 175
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
