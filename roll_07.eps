/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 375
  /ImageMatrix [700 0 0 375 0 0]
  /Width 700
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
